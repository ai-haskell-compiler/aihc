{
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "(clear|logout|prompt_input_exit)",
        "hooks": [
          {
            "type": "command",
            "command": "git switch main && git pull --ff-only",
            "name": "git-sync-on-session-end",
            "description": "Switch to main branch and pull latest changes when session ends"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(write_file|edit)",
        "hooks": [
          {
            "type": "command",
            "command": "nix run .#fmt",
            "name": "format-after-edit",
            "description": "Run nix formatter after write_file or edit tool use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".qwen/hooks/nix-flake-check.sh",
            "name": "nix-flake-check",
            "description": "Run nix flake check before stopping; continue if it fails",
            "timeout": 300000
          }
        ]
      }
    ]
  }
}
