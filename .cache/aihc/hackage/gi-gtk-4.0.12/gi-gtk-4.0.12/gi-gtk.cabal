name:           gi-gtk
version:        4.0.12
synopsis:       Gtk 4.x bindings (compatibility layer)
description:    This package re-exports (for backward compatibility)
                the haskell-gi generated bindings in the gi-gtk4 package.
homepage:       https://github.com/haskell-gi/haskell-gi
license:        LGPL-2.1
license-file:   LICENSE
author:         Iñaki García Etxebarria
maintainer:     Iñaki García Etxebarria
category:       Bindings
build-type:     Custom
cabal-version:  2.0

extra-source-files: README.md

custom-setup
 setup-depends:
   base >= 4.11 && <5,
   haskell-gi ^>= 0.26.14,
   gi-gtk4 ^>= 4.0.12

library
    ghc-options: -Wall

    build-depends: base >= 4.11 && <5,
                   gi-gtk4 ^>= 4.0.12

    default-language: Haskell2010
