cabal-version:      3.8
name:               aihc-parser
version:            0.1.0.0
build-type:         Simple
license:            MIT
license-file:       LICENSE
author:             David Himmelstrup
maintainer:         lemmih@gmail.com
category:           Compilers
synopsis:           From-scratch Haskell parser with differential tests

library
  exposed-modules:
      Aihc.Parser
    , Aihc.Parser.Syntax
    , Aihc.Parser.Lex
    , Aihc.Parser.Shorthand
    , Aihc.Parser.Internal.FromTokens
  other-modules:
      Aihc.Parser.Pretty
    , Aihc.Parser.Types
    , Aihc.Parser.Internal.Common
    , Aihc.Parser.Internal.Expr
    , Aihc.Parser.Internal.Decl
    , Aihc.Parser.Internal.Module
  hs-source-dirs:   src
  build-depends:
      base >=4.16 && <5
    , text >=1.2
    , containers
    , bytestring
    , deepseq
    , megaparsec
    , prettyprinter
  ghc-options:        -Wall -Werror
  default-language: GHC2021

test-suite spec
  type:             exitcode-stdio-1.0
  hs-source-dirs:
      test
    , common
  main-is:          Spec.hs
  other-modules:
      CppSupport
    , ExtensionSupport
    , GhcOracle
    , HackageSupport
    , HackageTester.CLI
    , HackageTester.Model
    , HseExtensions
    , LexerGolden
    , ParserErrorGolden
    , ParserGolden
    , ParserValidation
    , ShrinkUtils
    , StackageProgress.Summary
    , Test.ErrorMessages.Suite
    , Test.Oracle.Suite
    , Test.ExtensionMapping.Suite
    , Test.HackageTester.Suite
    , Test.Lexer.Suite
    , Test.Properties.ExprHelpers
    , Test.Properties.ExprRoundTrip
    , Test.Properties.ModuleRoundTrip
    , Test.Properties.Identifiers
    , Test.Properties.NoExceptions
    , Test.Properties.PatternRoundTrip
    , Test.Properties.TypeRoundTrip
    , Test.Parser.Suite
    , Test.StackageProgress.Summary
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , megaparsec
    , text
    , containers
    , directory
    , filepath
    , deepseq
    , tasty
    , tasty-hunit
    , tasty-quickcheck
    , QuickCheck
    , ghc-lib-parser
    , Cabal-syntax
    , haskell-src-exts
    , aeson
    , bytestring
    , prettyprinter
    , process
    , yaml
    , optparse-applicative
    , template-haskell
  ghc-options:        -Wall -Werror -threaded -rtsopts -with-rtsopts=-N
  default-language: Haskell2010

executable parser-progress
  hs-source-dirs:
      app/parser-progress
    , common
  main-is:          Main.hs
  other-modules:
      CppSupport
    , ExtensionSupport
    , GhcOracle
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , text
    , containers
    , directory
    , filepath
    , ghc-lib-parser
    , Cabal-syntax
    , prettyprinter
  ghc-options:        -Wall -Werror
  default-language: Haskell2010

executable parser-quickcheck-batch
  hs-source-dirs:
      app/parser-quickcheck-batch
    , common
    , test
  main-is:          Main.hs
  other-modules:
      CppSupport
    , ParserQuickCheck.CLI
    , ParserQuickCheck.Registry
    , ParserQuickCheck.Runner
    , ParserQuickCheck.Types
    , Test.Properties.ExprHelpers
    , Test.Properties.ExprRoundTrip
    , Test.Properties.ModuleRoundTrip
    , Test.Properties.Identifiers
    , Test.Properties.NoExceptions
    , Test.Properties.PatternRoundTrip
    , Test.Properties.TypeRoundTrip
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , text
    , aeson
    , QuickCheck
    , containers
    , bytestring
    , filepath
    , deepseq
    , optparse-applicative
    , time
    , prettyprinter
  ghc-options:        -Wall -Werror
  default-language: Haskell2010

executable lexer-progress
  hs-source-dirs:
      app/lexer-progress
    , common
  main-is:          Main.hs
  other-modules:
      LexerGolden
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , text
    , bytestring
    , containers
    , directory
    , filepath
    , aeson
    , yaml
  ghc-options:        -Wall -Werror
  default-language: Haskell2010

executable extension-progress
  hs-source-dirs:
      app/extension-progress
    , common
  main-is:          Main.hs
  other-modules:
      CppSupport
    , ExtensionSupport
    , GhcOracle
    , ParserGolden
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , text
    , containers
    , directory
    , filepath
    , ghc-lib-parser
    , Cabal-syntax
    , prettyprinter
    , yaml
    , aeson
    , bytestring
  ghc-options:        -Wall -Werror
  default-language: Haskell2010

executable hackage-tester
  hs-source-dirs:
      app/hackage-tester
    , common
  main-is:          Main.hs
  other-modules:
      ConcurrentProgress
    , CppSupport
    , GhcOracle
    , HackageSupport
    , HackageTester.CLI
    , HackageTester.Model
    , HseExtensions
    , ParserValidation
    , ShrinkUtils
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , text
    , containers
    , deepseq
    , directory
    , filepath
    , ghc-lib-parser
    , Cabal
    , Cabal-syntax
    , bytestring
    , process
    , async
    , aeson
    , http-client
    , http-client-tls
    , optparse-applicative
    , haskell-src-exts
    , prettyprinter
  ghc-options:        -Wall -Werror -threaded -rtsopts -with-rtsopts=-N
  default-language: Haskell2010

executable stackage-progress
  hs-source-dirs:
      app/stackage-progress
    , common
  main-is:          Main.hs
  other-modules:
      ConcurrentProgress
    , CppSupport
    , GhcOracle
    , HackageSupport
    , HseExtensions
    , ParserValidation
    , ShrinkUtils
    , StackageProgress.CLI
    , StackageProgress.FileChecker
    , StackageProgress.PackageRunner
    , StackageProgress.Snapshot
    , StackageProgress.Summary
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , text
    , containers
    , deepseq
    , directory
    , filepath
    , ghc-lib-parser
    , process
    , async
    , Cabal
    , Cabal-syntax
    , bytestring
    , haskell-src-exts
    , optparse-applicative
    , prettyprinter
  ghc-options:        -Wall -Werror -threaded -rtsopts -with-rtsopts=-N
  default-language: Haskell2010

executable parser-fuzz
  hs-source-dirs:
      app/parser-fuzz
    , common
  main-is:          Main.hs
  other-modules:
      CppSupport
    , GhcOracle
    , HseExtensions
    , ParserValidation
    , ShrinkUtils
    , ParserFuzz.CLI
    , ParserFuzz.Testing
    , ParserFuzz.Types
    , ParserFuzz.Arbitrary
  build-depends:
      base >=4.16 && <5
    , aihc-parser
    , aihc-cpp
    , deepseq
    , haskell-src-exts
    , QuickCheck
    , optparse-applicative
    , random
    , text
    , containers
    , filepath
    , ghc-lib-parser
    , Cabal-syntax
    , prettyprinter
  ghc-options:        -Wall -Werror
  default-language: GHC2021

test-suite parser-quickcheck-tests
  type:             exitcode-stdio-1.0
  hs-source-dirs:
      test/quickcheck-batch
    , common
  main-is:          Spec.hs
  other-modules:
      ParserQuickCheck.CLI
    , ParserQuickCheck.Runner
    , ParserQuickCheck.Types
    , Test.ParserQuickCheck.CLI
    , Test.ParserQuickCheck.Runner
  build-depends:
      base >=4.16 && <5
    , aeson
    , QuickCheck
    , containers
    , tasty
    , tasty-hunit
    , text
    , time
    , optparse-applicative
  ghc-options:        -Wall -Werror -threaded -rtsopts -with-rtsopts=-N
  default-language: Haskell2010
